@model GetMessageByIdDto
@{
    ViewData["Title"] = "AnswerMessageWithAI";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Gemini İle Otomatik Mesaj Yanıt Sayfası</h4>
                    </div>
                    <div class="card-body">
                        <form method="post">
                            <input type="hidden" asp-for="MessageId" />
                            <label>Müşteri Mesajı</label>
                            <textarea class="form-control" asp-for="MessageDetails" style="height: 150px !important;"></textarea>
                            <br />

                            <input type="hidden" asp-for="MessageId" />
                            <label>Gemini Otomatik Cevabı</label>
                            <textarea class="form-control" style="height: 150px !important;">@ViewBag.answerAI</textarea>
                            <br />
                            <button class="btn btn-primary">Cevabı Mail Olarak Gönder</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
